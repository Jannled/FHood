{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "git push *": "ask",
      "grep *": "allow",
      "git status": "allow",
    },
    "edit": {
      "opencode.json": "ask"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  }
}
